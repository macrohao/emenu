{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "handler": { "type": "filesystem" } },
    { "src": "/api/(.*)", "dest": "https://emenu-server-api.vercel.app/api/$1" },
    { "src": "/uploads/(.*)", "dest": "https://emenu-server-api.vercel.app/uploads/$1" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
